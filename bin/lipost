#!/usr/bin/env python3
"""lipost — LinkedIn posting suite.

Three layers, one binary:

  Primitive   lipost {init,auth,whoami,post,edit,delete}
              Direct LinkedIn API operations.

  Article     lipost article <url>
              URL → Claude → reviewed draft → posted (or queued).

  Bot/queue   lipost {drafts,bot} ...
              Draft queue, image generation, launchd-driven autoposter.

Run `lipost cheatsheet` for a curated short list, or `lipost <cmd> --help`.

Single file, Python 3 stdlib only — no `pip install`. macOS for the bot
(uses launchd); the rest is portable.
"""
from __future__ import annotations

import argparse
import base64
import json
import os
import random
import re
import secrets
import shutil
import subprocess
